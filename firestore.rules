rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'truongthanh.nongtruong@gmail.com'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Rules
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() <= 100
        && (!('birthDate' in data) || data.birthDate is string)
        && (!('shopeeId' in data) || data.shopeeId is string)
        && (!('photoURL' in data) || data.photoURL is string)
        && (!('tiktokId' in data) || data.tiktokId is string)
        && (!('apiToken' in data) || (data.apiToken is string && data.apiToken.size() == 36))
        && (!('role' in data) || data.role in ['user', 'admin'])
        && data.createdAt is string;
    }

    // Product Link Rules
    function isValidProduct(data) {
      return data.keys().hasAll(['userId', 'url', 'status', 'createdAt'])
        && data.userId == request.auth.uid
        && data.url is string && data.url.size() <= 1000
        && data.status in ['pending', 'quoted', 'purchased', 'completed', 'rejected']
        && (!('title' in data) || data.title is string)
        && (!('description' in data) || data.description is string)
        && (!('imageUrl' in data) || data.imageUrl is string)
        && (!('userPhoto' in data) || data.userPhoto is string)
        && (!('price' in data) || data.price is string)
        && (!('adminQuotePrice' in data) || data.adminQuotePrice is string)
        && (!('adminQuoteLink' in data) || data.adminQuoteLink is string)
        && (!('adminNote' in data) || data.adminNote is string)
        && data.createdAt is string;
    }

    // Post Rules
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 10000
        && (!('imageUrl' in data) || data.imageUrl is string)
        && data.createdAt is string;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isVerified() && isValidId(userId) && userId == request.auth.uid 
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'birthDate', 'shopeeId', 'tiktokId', 'photoURL', 'onboardingCompleted', 'apiToken']);
      allow delete: if false;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /posts/{postId} {
      allow list, get: if true;
      allow create: if isAdmin() && isValidPost(incoming());
      allow update: if isAdmin() && isValidPost(incoming());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow list: if (resource.data.status == 'completed') || (isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid));
      allow get: if (resource.data.status == 'completed') || (isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid));
      allow create: if isVerified() && isValidProduct(incoming()) && incoming().status == 'pending';
      allow update: if isVerified() && (
        isAdmin() || 
        (existing().userId == request.auth.uid && (
          // User marking as purchased
          (existing().status == 'quoted' && incoming().status == 'purchased' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        ))
      );
      allow delete: if isAdmin();
    }
  }
}
